generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?   // Added for avatar in comments
  passwordHash  String
  role          Role      @default(VOLUNTEER)
  availability  String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  shifts        Shift[]
  accounts      Account[]
  sessions      Session[]
  availabilitySlots  AvailabilitySlot[]
  shiftAssignments   ShiftAssignment[]
  requests      ShiftRequest[] @relation("Requester")
  reviewedRequests ShiftRequest[] @relation("Reviewer")
  newHelperRequests ShiftRequest[] @relation("NewHelper")
  contactEvents Event[]
  eventAssignments EventCrew[]
  volunteerApplications VolunteerApplication[] @relation("Applicant")
  reviewedApplications  VolunteerApplication[] @relation("ApplicationReviewer")
  notifications   Notification[] @relation("user")
  chatMessages    ChatMessage[] @relation("user")
}

enum Role {
  ADMIN
  CREW
  VOLUNTEER
}

enum ShiftAssignmentRole {
  RESPONSIBLE
  HELPER
}

model Shift {
  id           String   @id @default(cuid())
  title        String
  start        DateTime
  end          DateTime
  eventId      String
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  helperId     String?  // DEPRECATED: Use assignments instead. Kept for backward compatibility.
  helper       User?    @relation(fields: [helperId], references: [id], onDelete: SetNull)
  minHelpers   Int      @default(1)
  maxHelpers   Int      @default(1)
  assignments  ShiftAssignment[]
  requests     ShiftRequest[]
  chatMessages ChatMessage[] @relation("chatMessages")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Event {
  id            String   @id @default(cuid())
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime
  location      String?
  contactPersonId String?
  contactPerson User?    @relation(fields: [contactPersonId], references: [id])
  isArchived    Boolean  @default(false)
  archivedAt    DateTime?
  acceptingVolunteers Boolean @default(false)  // Whether volunteers can apply to this event
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  shifts        Shift[]
  crew          EventCrew[]
  shiftRequests ShiftRequest[]
  volunteerApplications VolunteerApplication[]
}

model EventCrew {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model ShiftAssignment {
  id        String              @id @default(cuid())
  shiftId   String
  userId    String
  role      ShiftAssignmentRole @default(HELPER)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  shift     Shift               @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shiftId, userId])
}

model EventTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String?
  defaultShifts Json     // Array of { title: string, startOffset: number (hours from event start), endOffset: number, recurrence?: string }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AvailabilitySlot {
  id              String   @id @default(cuid())
  userId          String
  start           DateTime
  end             DateTime
  isRecurring     Boolean  @default(false)
  recurrencePattern String? // e.g., "weekly", "monthly"
  recurrenceEnd   DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum RequestType {
  SWAP
  CANCEL
  MODIFY
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

model ShiftRequest {
  id          String       @id @default(cuid())
  shiftId     String
  eventId     String
  requesterId String
  type        RequestType
  status      RequestStatus @default(PENDING)
  reason      String?
  newHelperId String?      // For swap requests
  newStart    DateTime?    // For modify requests
  newEnd      DateTime?    // For modify requests
  reviewedBy  String?      // Admin who reviewed
  reviewedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  shift       Shift        @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  requester   User         @relation("Requester", fields: [requesterId], references: [id])
  newHelper   User?        @relation("NewHelper", fields: [newHelperId], references: [id])
  reviewer    User?        @relation("Reviewer", fields: [reviewedBy], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model VolunteerApplication {
  id          String            @id @default(cuid())
  eventId     String
  userId      String
  status      ApplicationStatus @default(PENDING)
  message     String?           // Optional message from volunteer
  reviewedBy  String?           // Admin who reviewed
  reviewedAt  DateTime?
  reviewNote  String?           // Admin note on decision
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User              @relation("Applicant", fields: [userId], references: [id], onDelete: Cascade)
  reviewer    User?             @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  @@unique([eventId, userId])  // One application per user per event
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  type          String
  payload       Json?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "user")
}

model ChatMessage {
  id            String   @id @default(cuid())
  userId        String
  shiftId       String
  message       String
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "user")
  shift         Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade, name: "chatMessages")
}